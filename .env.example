MONGO_URI=
JWT_SECRET=change-this-secret
REDIS_URL=redis://localhost:6379
PYTHON_AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# Generative AI, optional. The AI Hub works with fallbacks without these.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Live-data APIs, optional free tiers.
GOOGLE_PLACES_API_KEY=
NEWSAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
TWITTER_BEARER_TOKEN=

# Cloud media uploads. Free-tier Cloudinary works for profile/post images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Keep local development light. Set 0 if you want sentence-transformers to load.
CONNECTHUB_DISABLE_HEAVY_AI=1
